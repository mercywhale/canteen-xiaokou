<!--pages/admin/admin.wxml-->
<view class="container">
  <view class="section">
    <view class="section-title">📊 报表导出</view>

    <view class="date-bar">
      <text class="label">选择日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="date-picker">{{dateText}}</view>
      </picker>
      <button class="btn-today" size="mini" bindtap="setToday">今天</button>
    </view>

    <button class="btn-action" bindtap="exportDay">
      ⬇️ 导出当日订餐报表
    </button>

    <button class="btn-action btn-all" bindtap="exportAll">
      📊 导出全部历史记录
    </button>
  </view>

  <view class="section">
    <view class="section-title">📋 数据统计</view>
    <view class="stat-item" wx:for="{{stats}}" wx:key="name">
      <text class="stat-name">{{item.name}}</text>
      <view class="stat-nums">
        <text class="num bf">{{item.breakfast}}早</text>
        <text class="num lu">{{item.lunch}}午</text>
        <text class="num di">{{item.dinner}}晚</text>
      </view>
    </view>
    <view class="stat-tip">本月累计统计</view>
  </view>
</view>
