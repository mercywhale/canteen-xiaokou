/* pages/admin/admin.wxss */
.container{padding:20rpx}
.section{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:24rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.05)}
.section-title{font-size:32rpx;font-weight:700;margin-bottom:20rpx;color:#333}
.date-bar{display:flex;align-items:center;gap:16rpx;margin-bottom:24rpx}
.label{font-size:28rpx;color:#888;white-space:nowrap}
.date-picker{flex:1;border:1px solid #E0E0E0;border-radius:12rpx;padding:12rpx 20rpx;font-size:28rpx;text-align:center}
.btn-today{background:#4CAF50!important;color:#fff!important;font-size:26rpx!important;border-radius:12rpx!important}
.btn-action{width:100%;background:#fff;color:#4CAF50;border:3rpx solid #4CAF50;border-radius:16rpx;font-size:30rpx;font-weight:700;padding:24rpx;margin-bottom:16rpx}
.btn-all{color:#FF7043;border-color:#FF7043;margin-bottom:0}
.stat-item{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;border-bottom:1px solid #F5F5F5}
.stat-name{font-size:28rpx;font-weight:600}
.stat-nums{display:flex;gap:12rpx}
.num{padding:6rpx 16rpx;border-radius:20rpx;font-size:24rpx;color:#fff;font-weight:600}
.num.bf{background:#FF9800}.num.lu{background:#2196F3}.num.di{background:#9C27B0}
.stat-tip{text-align:center;color:#888;font-size:24rpx;margin-top:16rpx}
